{
  "_comment": "Template — fields with {{ ... }} are replaced per-vendor by wrap-vendor.ps1. Do not edit this file by hand for a build; edit the script's parameters and re-run.",
  "appId": "{{BUNDLE_ID}}",
  "appName": "{{APP_NAME}}",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "{{PRIMARY_COLOR}}",
      "showSpinner": true,
      "androidSpinnerStyle": "small",
      "iosSpinnerStyle": "small",
      "spinnerColor": "#ffffff"
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "{{PRIMARY_COLOR}}"
    },
    "Keyboard": {
      "resize": "body",
      "style": "DARK"
    },
    "Camera": {
      "permissions": ["camera", "photos"]
    },
    "Geolocation": {
      "permissions": ["location"]
    }
  },
  "ios": {
    "scheme": "{{APP_NAME_SAFE}}",
    "contentInset": "always"
  },
  "android": {
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false,
    "minWebViewVersion": 60
  }
}
