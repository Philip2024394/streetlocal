# Per-vendor builds are NOT committed to git by default.
# Each vendor build is regenerated by wrap-vendor.ps1 from food-basic/ + template/.
# Only commit builds/ when triggering an iOS Actions build (push to wrap/* branch).
#
# When ready to trigger an iOS build, force-add the specific vendor:
#   git add -f wrap/builds/donut-king
#
# Otherwise everything in builds/ is gitignored.

builds/

# Common per-build noise we never want
**/node_modules/
**/dist/
**/.env
**/.env.production
**/android/app/build/
**/android/.gradle/
**/android/local.properties
**/ios/Pods/
**/ios/App/build/
**/ios/App/Pods/
**/ios/DerivedData/
**/*.xcuserdata/
**/.DS_Store
**/Thumbs.db

# Signing artefacts — should be in GitHub Actions secrets, never in repo
**/*.p12
**/*.mobileprovision
**/*.keystore
**/key.properties
