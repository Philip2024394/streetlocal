# Supabase
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase CLI (optional, used for local migrations / linked queries)
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# ─── Food Local Chat — Web Push ─────────────────────────
# Generate with: npx web-push generate-vapid-keys
# Vite exposes only VITE_* prefixed vars to the client; the public key is
# used by both the customer subscribe call (rare) and the vendor inbox.
VITE_VAPID_PUBLIC_KEY=

# Server-side keys (NEVER ship in client bundles). Set via:
#   npx supabase secrets set VAPID_PUBLIC_KEY=... VAPID_PRIVATE_KEY=... VAPID_SUBJECT=mailto:you@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:alerts@streetlocal.live
